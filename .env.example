APP_NAME="Vitrine AI Pro"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vitrine_ai_pro
DB_USERNAME=root
DB_PASSWORD=

SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

CACHE_STORE=file
QUEUE_CONNECTION=sync
FILESYSTEM_DISK=public

MAIL_MAILER=log
MAIL_FROM_ADDRESS="contato@vitrineaipro.com.br"
MAIL_FROM_NAME="${APP_NAME}"

# Chave privada usada somente por formulários processados no servidor.
# Gere com: php -r "echo bin2hex(random_bytes(32)), PHP_EOL;"
LEAD_CAPTURE_KEY=
LEAD_CAPTURE_REQUIRE_CONSENT=true
